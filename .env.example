# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHANNEL=@your_channel

# Optional: your personal chat_id. If set, the bot DMs you a ready-to-paste
# tweet + share-card image after each daily post (see README "X / Twitter").
TELEGRAM_ADMIN_CHAT_ID=

# Google AI Studio (Gemini)
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# Branding shown in the digest footer
SITE_URL=zromek.de
CHANNEL_HANDLE=@your_channel

# How many news items the digest should contain
DIGEST_MIN=4
DIGEST_MAX=6
